<Window x:Class="Yatzy.MainWindow"
        x:Name="MainWindowInstance"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Яцы"
        Width="1100"
        Height="740"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="#FBFBFA">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="1"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="GridScale" ScaleX="1" ScaleY="1"/>
        </Grid.RenderTransform>
        
        <wv2:WebView2 x:Name="_wv"/>
        
        <!-- Оверлей для гладких анимаций окна -->
        <Image x:Name="ScreenshotOverlay" Stretch="UniformToFill" Visibility="Hidden" RenderOptions.BitmapScalingMode="HighQuality"/>
    </Grid>
</Window>
